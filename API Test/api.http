  "privacy": "PUBLIC"
}


# ═══════════════════════════════════════════════════════════════
# 11. SECURITY & HEADERS
# ═══════════════════════════════════════════════════════════════

### 11.1 Protected endpoint — no token (expect 401)
GET {{baseUrl}}/users/me

###

### 11.2 Protected endpoint — invalid token (expect 401)
GET {{baseUrl}}/users/me
Authorization: Bearer not.a.valid.jwt.token

###

### 11.3 Protected endpoint — tampered signature (expect 401)
GET {{baseUrl}}/posts/feed
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhbGljZSJ9.invalidsignature

###

### 11.4 Protected endpoint — expired token structure (expect 401)
GET {{baseUrl}}/notifications
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJhbGljZSIsImlhdCI6MTAwMDAwMDAwMCwiZXhwIjoxMDAwMDg2NDAwfQ.fake_sig

###

### 11.5 X-Content-Type-Options header check ✅
# Verify "nosniff" in response headers
GET {{baseUrl}}/users/alice
Authorization: Bearer {{token}}

###

### 11.6 X-RateLimit headers check ✅
# Verify X-RateLimit-Limit and X-RateLimit-Remaining are present
GET {{baseUrl}}/posts/feed?page=0&size=1
Authorization: Bearer {{token}}

###

### 11.7 SQL injection in search — should return 200 (not 500)
GET {{baseUrl}}/search/users?q=%27+OR+%271%27%3D%271
Authorization: Bearer {{token}}

###

### 11.8 XSS payload in post content — stored safely, not executed
POST {{baseUrl}}/posts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "content": "<script>alert('xss')</script> #security",
  "privacy": "PRIVATE"
}

###

### 11.9 No stack trace in 404 error body — verify clean error response
GET {{baseUrl}}/posts/99999999
Authorization: Bearer {{token}}

###

### 11.10 Self-follow prevention ❌ — (expect 403)
POST {{baseUrl}}/users/alice/follow
Authorization: Bearer {{token}}
