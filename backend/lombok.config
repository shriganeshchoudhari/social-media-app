# Lombok configuration for Social Media Clone backend
# This file tells Lombok to stop searching parent directories for config
config.stopBubbling = true

# Enable Lombok's builder, getters, setters, constructors (explicit for clarity)
lombok.addLombokGeneratedAnnotation = true

# Ensure @EqualsAndHashCode and @ToString use field access, not getter
lombok.equalsAndHashCode.callSuper = skip

# Suppress warnings about Lombok-generated code in code analysis tools
lombok.anyConstructor.addConstructorProperties = false

# Copy non-null annotations to generated code (helps IDE analysis)
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
lombok.copyableAnnotations += org.springframework.context.annotation.Lazy
