            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-POST-002: Status 201 Created', () => { pm.response.to.have.status(201); });",
                  "pm.test('TC-POST-002: Content length is exactly 280', () => {",
                  "    pm.expect(pm.response.json().content.length).to.equal(280);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
