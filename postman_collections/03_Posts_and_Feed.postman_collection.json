    {
      "name": "Feed",
      "item": [
        {
          "name": "✅ TC-FEED-001 Standard paginated feed",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-FEED-001: Status 200 OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-FEED-001: Paginated feed structure', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('content');",
                  "    pm.expect(pm.response.json().content).to.be.an('array');",
                  "});",
                  "pm.test('TC-FEED-001: Feed posts sorted newest first', () => {",
                  "    const posts = pm.response.json().content;",
                  "    if (posts.length > 1) {",
                  "        pm.expect(new Date(posts[0].createdAt).getTime()).to.be.at.least(new Date(posts[1].createdAt).getTime());",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/posts/feed?page=0&size=20",
              "host": ["{{BASE_URL}}"],
              "path": ["posts", "feed"],
              "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }]
            }
          }
