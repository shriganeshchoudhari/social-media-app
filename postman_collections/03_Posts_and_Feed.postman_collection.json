        {
          "name": "✅ TC-POST-012 Delete own post",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.environment.get('BASE_URL');",
                  "const token = pm.environment.get('ALICE_TOKEN');",
                  "pm.sendRequest({",
                  "    url: `${baseUrl}/posts`,",
                  "    method: 'POST',",
                  "    header: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ content: 'Post to be deleted' }) }",
                  "}, (err, res) => {",
                  "    if (!err) pm.environment.set('DELETE_POST_ID', res.json().id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-POST-012: Status 204 No Content', () => { pm.response.to.have.status(204); });",
                  "pm.test('TC-POST-012: Response body is empty', () => { pm.expect(pm.response.text()).to.be.empty; });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{DELETE_POST_ID}}", "host": ["{{BASE_URL}}"], "path": ["posts", "{{DELETE_POST_ID}}"] }
