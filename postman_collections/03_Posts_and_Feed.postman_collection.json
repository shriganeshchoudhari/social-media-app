{
  "info": {
    "_postman_id": "ch-posts-col-003",
    "name": "03 - ConnectHub Posts & Feed",
    "description": "Post creation, editing, deletion, feed pagination, and cursor-based pagination (TC-POST-001 to TC-POST-018, TC-FEED-001 to TC-FEED-008).\n\nPrerequisite: Run collection 01 first so ALICE_TOKEN, BOB_TOKEN are set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.environment.get('ALICE_TOKEN')) {",
          "    console.warn('ALICE_TOKEN not set — run collection 01 first');",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Response time < 2000ms', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "✅ TC-POST-001 Create text post",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "pm.environment.set('POST_CONTENT', `Hello world from E2E test at ${ts}! #testing`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-POST-001: Status 201 Created', () => { pm.response.to.have.status(201); });",
                  "pm.test('TC-POST-001: Post object returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json.content).to.equal(pm.environment.get('POST_CONTENT'));",
                  "    pm.expect(json.author.username).to.equal('alice');",
                  "    pm.expect(json.likesCount).to.equal(0);",
                  "    pm.expect(json.commentsCount).to.equal(0);",
                  "    pm.expect(json).to.have.property('createdAt');",
                  "    pm.environment.set('CREATED_POST_ID', json.id);",
                  "    pm.environment.set('ALICE_POST_ID', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"{{POST_CONTENT}}\"\n}" },
            "url": { "raw": "{{BASE_URL}}/posts", "host": ["{{BASE_URL}}"], "path": ["posts"] }
          }
        },
        {
          "name": "✅ TC-POST-002 Create post at max length (280 chars)",
