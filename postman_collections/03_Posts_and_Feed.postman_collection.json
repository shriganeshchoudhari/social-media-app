          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/posts/feed", "host": ["{{BASE_URL}}"], "path": ["posts", "feed"] }
          }
        },
        {
          "name": "✅ TC-FEED-004 Cursor-based feed initial load",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-FEED-004: Status 200 OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-FEED-004: Cursor response shape', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('posts');",
                  "    pm.expect(json).to.have.property('nextCursor');",
                  "    pm.expect(json).to.have.property('hasMore');",
                  "    pm.expect(json.posts).to.be.an('array');",
                  "    if (json.nextCursor) pm.environment.set('CURSOR_VALUE', json.nextCursor);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/posts/feed/cursor?size=20",
              "host": ["{{BASE_URL}}"],
              "path": ["posts", "feed", "cursor"],
              "query": [{ "key": "size", "value": "20" }]
            }
          }
        },
        {
          "name": "✅ TC-FEED-005 Cursor-based feed next page",
          "event": [
            { "listen": "prerequest", "script": { "exec": ["// Uses CURSOR_VALUE from previous request"], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-FEED-005: Status 200 OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-FEED-005: Posts are older than cursor', () => {",
                  "    const json = pm.response.json();",
                  "    const cursor = pm.environment.get('CURSOR_VALUE');",
                  "    if (json.posts.length > 0 && cursor) {",
                  "        json.posts.forEach(p => {",
                  "            pm.expect(new Date(p.createdAt).getTime()).to.be.below(new Date(cursor).getTime());",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
