{
  "info": {
    "_postman_id": "ch-social-col-004",
    "name": "04 - ConnectHub Social Features",
    "description": "Likes, Bookmarks, Comments, and Follow system (TC-LIKE-001 to TC-LIKE-009, TC-COMMENT-001 to TC-COMMENT-007, TC-FOLLOW-001 to TC-FOLLOW-007).\n\nPrerequisite: Run collections 01 and 03 first so tokens and ALICE_POST_ID are set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.environment.get('ALICE_TOKEN') || !pm.environment.get('ALICE_POST_ID')) {",
          "    console.warn('Missing ALICE_TOKEN or ALICE_POST_ID — run collections 01 and 03 first');",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Response time < 2000ms', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Likes",
      "item": [
        {
          "name": "✅ TC-LIKE-001 Like a post",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-LIKE-001: Status 200 OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-LIKE-001: liked=true in response', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.liked).to.equal(true);",
                  "    pm.expect(json.likesCount).to.be.a('number').and.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/like", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "like"] }
          }
        },
        {
          "name": "❌ TC-LIKE-002 Like same post twice",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-LIKE-002: Status 200 (toggle) or 409 (conflict)', () => {",
                  "    pm.expect([200, 409]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/like", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "like"] }
          }
        },
        {
          "name": "✅ TC-LIKE-001b Bob likes post (setup for unlike)",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Bob likes post: Status 200', () => { pm.expect([200,409]).to.include(pm.response.code); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{BOB_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/like", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "like"] }
          }
        },
        {
          "name": "✅ TC-LIKE-003 Unlike a post",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-LIKE-003: Status 200 OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-LIKE-003: liked=false in response', () => {",
                  "    pm.expect(pm.response.json().liked).to.equal(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{BOB_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/like", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "like"] }
          }
        },
        {
          "name": "❌ TC-LIKE-004 Unlike a post not previously liked",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-LIKE-004: Status 400 Bad Request', () => { pm.response.to.have.status(400); });",
                  "pm.test('TC-LIKE-004: Error about not having liked', () => {",
                  "    pm.expect(JSON.stringify(pm.response.json())).to.match(/not liked|have not liked/i);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{CHARLIE_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/like", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "like"] }
          }
        },
        {
          "name": "❌ TC-LIKE-005 Like non-existent post",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('TC-LIKE-005: Status 404 Not Found', () => { pm.response.to.have.status(404); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/9999999/like", "host": ["{{BASE_URL}}"], "path": ["posts", "9999999", "like"] }
          }
        }
      ]
    },
