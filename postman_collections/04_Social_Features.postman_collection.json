    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "✅ TC-COMMENT-001 Add comment to post",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-COMMENT-001: Status 201 Created', () => { pm.response.to.have.status(201); });",
                  "pm.test('TC-COMMENT-001: Comment object returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json.content).to.equal('Great post from E2E!');",
                  "    pm.expect(json.author.username).to.equal('alice');",
                  "    pm.expect(json).to.have.property('createdAt');",
                  "    pm.environment.set('CREATED_COMMENT_ID', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Great post from E2E!\"\n}" },
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/comments", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "comments"] }
          }
        },
        {
          "name": "❌ TC-COMMENT-002 Add empty comment",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('TC-COMMENT-002: Status 400 Bad Request', () => { pm.response.to.have.status(400); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"\"\n}" },
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/comments", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "comments"] }
          }
        },
        {
          "name": "❌ TC-COMMENT-003 Add comment to non-existent post",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('TC-COMMENT-003: Status 404 Not Found', () => { pm.response.to.have.status(404); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Comment on ghost post\"\n}" },
            "url": { "raw": "{{BASE_URL}}/posts/9999999/comments", "host": ["{{BASE_URL}}"], "path": ["posts", "9999999", "comments"] }
          }
        },
        {
          "name": "✅ TC-COMMENT-007 Get comments paginated",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-COMMENT-007: Status 200 OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-COMMENT-007: Paginated response', () => {",
                  "    pm.expect(pm.response.json().content).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/comments?page=0&size=10",
              "host": ["{{BASE_URL}}"],
              "path": ["posts", "{{ALICE_POST_ID}}", "comments"],
              "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "10" }]
            }
          }
        },
        {
          "name": "✅ TC-COMMENT-006 Post author deletes another's comment (moderation)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.environment.get('BASE_URL');",
                  "const bobToken = pm.environment.get('BOB_TOKEN');",
                  "const postId = pm.environment.get('ALICE_POST_ID');",
                  "pm.sendRequest({",
                  "    url: `${baseUrl}/posts/${postId}/comments`,",
                  "    method: 'POST',",
                  "    header: { 'Authorization': `Bearer ${bobToken}`, 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ content: 'Bob comment to be deleted by alice' }) }",
                  "}, (err, res) => {",
                  "    if (!err) pm.environment.set('BOB_COMMENT_ID', res.json().id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('TC-COMMENT-006: Status 204 No Content (author moderation)', () => { pm.response.to.have.status(204); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/comments/{{BOB_COMMENT_ID}}", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "comments", "{{BOB_COMMENT_ID}}"] }
          }
        },
        {
          "name": "✅ TC-COMMENT-004 Delete own comment",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('TC-COMMENT-004: Status 204 No Content', () => { pm.response.to.have.status(204); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/posts/{{ALICE_POST_ID}}/comments/{{CREATED_COMMENT_ID}}", "host": ["{{BASE_URL}}"], "path": ["posts", "{{ALICE_POST_ID}}", "comments", "{{CREATED_COMMENT_ID}}"] }
          }
        }
      ]
    },
