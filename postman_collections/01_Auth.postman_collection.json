{
  "info": {
    "_postman_id": "ch-auth-col-001",
    "name": "01 - ConnectHub Authentication",
    "description": "All authentication API test cases (TC-AUTH-001 to TC-AUTH-015).\nCovers registration, login, token validation, and injection attacks.\n\nRun order: Execute top-to-bottom. Tokens for Alice, Bob, Charlie, and Admin\nare auto-captured and stored in environment variables for use by other collections.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "id": "col-pre-auth",
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('BASE_URL')) {",
          "    pm.environment.set('BASE_URL', 'http://localhost:8080/api/v1');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "id": "col-test-auth",
        "type": "text/javascript",
        "exec": [
          "pm.test('Response time < 2000ms', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "✅ TC-AUTH-001 Register with valid data",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const ts = Date.now();",
              "const username = `e2e_user_${ts}`;",
              "pm.environment.set('DYNAMIC_USERNAME', username);",
              "pm.environment.set('DYNAMIC_EMAIL', `${username}@e2e.test`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-AUTH-001: Status 201 Created', () => { pm.response.to.have.status(201); });",
              "pm.test('TC-AUTH-001: Response has token', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('token');",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('TC-AUTH-001: User object in response', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('user');",
              "    pm.expect(json.user.username).to.equal(pm.environment.get('DYNAMIC_USERNAME'));",
              "    pm.expect(json.user.role).to.equal('USER');",
              "});",
              "pm.test('TC-AUTH-001: Password NOT in response', () => {",
              "    const body = pm.response.text();",
              "    pm.expect(body).to.not.include('Test1234!');",
              "    pm.expect(body).to.not.include('password_hash');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{DYNAMIC_USERNAME}}\",\n  \"email\": \"{{DYNAMIC_EMAIL}}\",\n  \"password\": \"Secure123!\",\n  \"displayName\": \"E2E Tester\"\n}"
        },
        "url": { "raw": "{{BASE_URL}}/auth/register", "host": ["{{BASE_URL}}"], "path": ["auth", "register"] }
      }
    },
    {
      "name": "❌ TC-AUTH-002 Register duplicate username",
      "event": [
        {
          "listen": "prerequest",
          "script": { "exec": ["// alice must already exist in DB (seed data)"], "type": "text/javascript" }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-AUTH-002: Status 409 Conflict', () => { pm.response.to.have.status(409); });",
              "pm.test('TC-AUTH-002: Error mentions username taken', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.error || json.message).to.match(/username|already taken/i);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"unique_dup@e2e.test\",\n  \"password\": \"Secure123!\",\n  \"displayName\": \"Duplicate\"\n}" },
        "url": { "raw": "{{BASE_URL}}/auth/register", "host": ["{{BASE_URL}}"], "path": ["auth", "register"] }
      }
    },
    {
      "name": "❌ TC-AUTH-003 Register duplicate email",
      "event": [
        { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
