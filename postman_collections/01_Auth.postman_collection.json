    {
      "name": "❌ TC-AUTH-014 SQL injection in login",
      "event": [
        { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-AUTH-014: Status 401 - SQL injection rejected', () => { pm.response.to.have.status(401); });",
              "pm.test('TC-AUTH-014: No SQL error in response', () => {",
              "    const body = pm.response.text().toLowerCase();",
              "    pm.expect(body).to.not.include('sql');",
              "    pm.expect(body).to.not.include('syntax error');",
              "    pm.expect(body).to.not.include('exception');",
              "});",
              "pm.test('TC-AUTH-014: No token returned', () => {",
              "    pm.expect(pm.response.json()).to.not.have.property('token');",
              "});"
            ],
            "type": "text/javascript"
          }
