          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-AUTH-008: Status 200 OK', () => { pm.response.to.have.status(200); });",
              "pm.test('TC-AUTH-008: Token returned when logging in via email', () => {",
              "    pm.expect(pm.response.json().token).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('TC-AUTH-008: Same user returned', () => {",
              "    pm.expect(pm.response.json().user.username).to.equal('alice');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"usernameOrEmail\": \"alice@example.com\",\n  \"password\": \"{{ALICE_PASSWORD}}\"\n}" },
        "url": { "raw": "{{BASE_URL}}/auth/login", "host": ["{{BASE_URL}}"], "path": ["auth", "login"] }
      }
    },
