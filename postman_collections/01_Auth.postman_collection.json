    },
    {
      "name": "✅ TC-AUTH-007 Login with valid credentials (Alice)",
      "event": [
        { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-AUTH-007: Status 200 OK', () => { pm.response.to.have.status(200); });",
              "pm.test('TC-AUTH-007: Token returned and stored', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "    pm.environment.set('ALICE_TOKEN', json.token);",
              "    if (json.user && json.user.id) pm.environment.set('ALICE_ID', json.user.id);",
              "});",
              "pm.test('TC-AUTH-007: Correct username returned', () => {",
              "    pm.expect(pm.response.json().user.username).to.equal('alice');",
              "});",
              "pm.test('TC-AUTH-007: Content-Type is JSON', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"usernameOrEmail\": \"{{ALICE_USERNAME}}\",\n  \"password\": \"{{ALICE_PASSWORD}}\"\n}" },
        "url": { "raw": "{{BASE_URL}}/auth/login", "host": ["{{BASE_URL}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "✅ TC-AUTH-008 Login with email instead of username",
      "event": [
        { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
