          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-AUTH-003: Status 409 Conflict', () => { pm.response.to.have.status(409); });",
              "pm.test('TC-AUTH-003: Error mentions email in use', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.error || json.message).to.match(/email|already in use/i);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"unique_user_dup\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Secure123!\",\n  \"displayName\": \"Unique\"\n}" },
        "url": { "raw": "{{BASE_URL}}/auth/register", "host": ["{{BASE_URL}}"], "path": ["auth", "register"] }
      }
    },
