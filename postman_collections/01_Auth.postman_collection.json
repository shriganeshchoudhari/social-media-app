        "body": { "mode": "raw", "raw": "{\n  \"username\": \"<script>alert(1)</script>\",\n  \"email\": \"xss@test.com\",\n  \"password\": \"Secure123!\",\n  \"displayName\": \"XSS Tester\"\n}" },
        "url": { "raw": "{{BASE_URL}}/auth/register", "host": ["{{BASE_URL}}"], "path": ["auth", "register"] }
