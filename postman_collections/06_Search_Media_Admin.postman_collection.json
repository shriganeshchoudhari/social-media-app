{
  "info": {
    "_postman_id": "ch-search-admin-col-006",
    "name": "06 - ConnectHub Search, Media & Admin",
    "description": "Search & Discovery, Media Upload, and Admin Panel endpoints (TC-SEARCH-001 to TC-SEARCH-009, TC-MEDIA-001 to TC-MEDIA-007, TC-ADMIN-001 to TC-ADMIN-010).\n\nPrerequisite: Run collection 01 so ALICE_TOKEN, BOB_TOKEN, ADMIN_TOKEN are set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.environment.get('ADMIN_TOKEN')) {",
          "    console.warn('ADMIN_TOKEN not set — run collection 01 first');",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test('Response time < 2000ms', () => {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Search & Discovery",
      "item": [
        {
          "name": "✅ TC-SEARCH-001 Search users by username",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-SEARCH-001: Status 200 OK', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-SEARCH-001: Alice appears in results for query \"ali\"', () => {",
                  "    const users = pm.response.json().content || pm.response.json();",
                  "    pm.expect(users).to.be.an('array');",
                  "    pm.expect(users.map(u => u.username)).to.include('alice');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/search/users?q=ali",
              "host": ["{{BASE_URL}}"],
              "path": ["search", "users"],
              "query": [{ "key": "q", "value": "ali" }]
            }
          }
        },
        {
          "name": "❌ TC-SEARCH-002 Search users empty query",
          "event": [
            { "listen": "prerequest", "script": { "exec": [""], "type": "text/javascript" } },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('TC-SEARCH-002: Status 400 or empty results', () => { pm.expect([200, 400]).to.include(pm.response.code); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/search/users?q=",
              "host": ["{{BASE_URL}}"],
              "path": ["search", "users"],
              "query": [{ "key": "q", "value": "" }]
            }
          }
        },
