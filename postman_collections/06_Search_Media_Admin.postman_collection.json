    {
      "name": "Media Upload",
      "item": [
        {
          "name": "❌ TC-MEDIA-003 Upload file exceeding size limit",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["// Attach a file > 50MB to the 'file' form-data field to trigger this test"],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('TC-MEDIA-003: Status 413 or 400', () => { pm.expect([400, 413]).to.include(pm.response.code); });"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "/path/to/large-file-over-50mb.bin", "description": "Replace with actual >50MB file" }]
            },
            "url": { "raw": "{{BASE_URL}}/media/upload", "host": ["{{BASE_URL}}"], "path": ["media", "upload"] }
          }
        },
