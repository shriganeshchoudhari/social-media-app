            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('TC-SEARCH-004: Status 200 — injection neutralized', () => { pm.response.to.have.status(200); });",
                  "pm.test('TC-SEARCH-004: No SQL error exposed in response', () => {",
                  "    const body = pm.response.text().toLowerCase();",
                  "    pm.expect(body).to.not.include('sql');",
                  "    pm.expect(body).to.not.include('syntax error');",
                  "    pm.expect(body).to.not.include('exception');",
                  "    pm.expect(body).to.not.include('drop table');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ALICE_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/search/posts?q=' OR '1'='1'; DROP TABLE posts;--",
              "host": ["{{BASE_URL}}"],
              "path": ["search", "posts"],
              "query": [{ "key": "q", "value": "' OR '1'='1'; DROP TABLE posts;--" }]
