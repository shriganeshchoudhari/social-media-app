# ConnectHub — environment variables template
# Copy to .env and fill in values before running in production.
# NEVER commit the actual .env to version control.

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=socialmedia
POSTGRES_USER=socialmedia
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_at_least_64_chars_base64_encoded_secret

# ── Ports ──────────────────────────────────────────────────────
BACKEND_PORT=9090
FRONTEND_PORT=3001

# ── AI (Ollama) ────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2:3b
# Override if Ollama runs on a different host/port:
# OLLAMA_BASE_URL=http://ollama:11434

# ── Frontend build ────────────────────────────────────────────
# Set to the public URL where the backend API is reachable
VITE_API_BASE_URL=http://localhost:9090
